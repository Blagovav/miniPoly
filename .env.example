# Telegram bot token from @BotFather
# Leave empty for local web-only development (bot polling will be disabled).
BOT_TOKEN=

# Public URL of the Mini App (HTTPS required for production).
# For local dev, use ngrok/cloudflared and put the https URL here.
WEBAPP_URL=http://localhost:5174

# Vite build-time config for the frontend
VITE_API_URL=http://localhost:3000
VITE_WS_URL=ws://localhost:3000/ws

# CORS origin allowed by the API
CORS_ORIGIN=http://localhost:5174

# Database
POSTGRES_USER=monopoly
POSTGRES_PASSWORD=monopoly
POSTGRES_DB=monopoly

NODE_ENV=development
