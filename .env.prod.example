# Telegram bot token from @BotFather — ОБЯЗАТЕЛЬНО
BOT_TOKEN=

# Username бота без @ (используется для t.me/<username>?startapp=... инвайтов)
BOT_USERNAME=poly_mini_bot

# Публичная картинка-превью (thumbnail) для красивой карточки приглашения
# через tg.shareMessage. PNG/JPG ≤1 МБ, рекомендуется 512×512. Если пусто —
# карточка шлётся без превью (заголовок + описание + кнопка всё равно есть).
OG_IMAGE_URL=https://tapcade.online/og.png

# Домен для Mini App (HTTPS, автоматический сертификат от Let's Encrypt).
WEBAPP_URL=https://tapcade.online

# CORS — тот же домен
CORS_ORIGIN=https://tapcade.online

# Postgres — смени пароль перед деплоем
POSTGRES_USER=monopoly
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=monopoly

NODE_ENV=production
